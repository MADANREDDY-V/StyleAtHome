sequenceDiagram
    actor User
    participant Frontend as React App
    participant Auth as Clerk
    participant DB as Supabase
    participant Admin as Admin Dashboard
    
    User->>Frontend: Book Home Trial
    Frontend->>Auth: Verify Session
    Auth-->>Frontend: Valid Token
    Frontend->>DB: INSERT into bookings (fee: 50)
    DB-->>Frontend: Success (Booking ID)
    DB-)Admin: Realtime Event: New Booking
    Frontend-->>User: Show Confirmation
