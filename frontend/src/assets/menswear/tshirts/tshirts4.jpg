 1.41-1.41z"></path></svg></span></span></div><div class="Htu6gf" style="display:none;" jsname="FbqEcd" aria-expanded="true" id="jsuid_1038-full" role="button" tabindex="0" jsaction="trigger.jKkd5b" data-ved="0CI8CEILyBGoXChMIgP-m_8uCkwMVAAAAAB0AAAAAEBQ" data-hveid="271"><span class="v168Le">The PUMA T-shirt is a great blend of comfort style and quality. Made with soft and breathable fabric it feels light on the skin and is perfect for both casual wear and workouts. The stitching and finish are neat giving it a durable and premium look while the iconic PUMA logo adds a sporty edge. It fits true to size offering good comfort without feeling too tight or loose. Whether for gym sessions or daily wear the PUMA T-shirt stands out as a reliable and stylish choice. Thank you Myntra.</span>&nbsp;<span class="Cf9mYb" data-less-button="" aria-label="Collapse review"><span class="Oz4Oxf" aria-hidden="true">Less</span><span class="n9sVdc jSGijb z1asCe" style="height:18px;line-height:18px;width:18px;"><svg focusable="false" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M7.41 15.41L12 10.83l4.59 4.58L18 14l-6-6-6 6z"></path></svg></span></span></div></div></div><div data-ved="0CJACEPXfBmoXChMIgP-m_8uCkwMVAAAAAB0AAAAAEBQ" class="RGS3bc"><div data-ved="0CJECEInCBmoXChMIgP-m_8uCkwMVAAAAAB0AAAAAEBQ" data-hveid="273" class="YZrmu" data-index="0" data-review-list-image="1" aria-label="User-submitted image 1 of 4 with link to image viewer." role="button" tabindex="0" jscontroller="EXN34" id="pve-srfs_1041" jsaction="rcuQ6b:npT2md;h5M12e" jsdata="f0J0ae;;374"><div class="ZemHff uhHOwf ez24Df" jsname="Ue2qW"><img alt="" id="dimg_1042" src="https://encrypted-tbn3.gstatic.com/shopping?q=tbn:ANd9GcRWK0P0TOeUkb83XpAWWcQqM26mRr7fvO1JIHw49-9GsCrrVKyMkbSUG3Ukl4MStppI4kRrAh6LmuB7fXgcL-5X8aEgFfUpT2M2varoJhZ3cyRVzhASKDg" data-ilt="1772501922673"></div></div><div data-ved="0CJMCEInCBmoXChMIgP-m_8uCkwMVAAAAAB0AAAAAEBQ" data-hveid="275" class="YZrmu" data-index="1"